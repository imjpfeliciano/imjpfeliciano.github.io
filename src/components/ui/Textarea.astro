---
interface Props {
  id?: string;
  name?: string;
  rows?: number;
  placeholder?: string;
  translateKey?: string;
  class?: string;
}

const {
  id,
  name,
  rows = 5,
  placeholder,
  translateKey,
  class: className = "",
} = Astro.props;
---

<textarea
  id={id}
  name={name}
  rows={rows}
  placeholder={placeholder}
  data-translate-placeholder={translateKey}
  class:list={[
    "w-full resize-none rounded-lg border border-slate-700 bg-slate-900/80 px-4 py-3 text-sm text-white placeholder:text-slate-500 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent",
    className,
  ]}></textarea>
