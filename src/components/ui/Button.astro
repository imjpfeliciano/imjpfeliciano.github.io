---
interface Props {
  variant?: "primary" | "outline";
  href?: string;
  type?: "button" | "submit";
  translateKey?: string;
  class?: string;
}

const {
  variant = "primary",
  href,
  type = "button",
  translateKey,
  class: className = "",
} = Astro.props;

const baseClasses =
  "inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 text-sm font-semibold transition-colors duration-200";

const variants = {
  primary: "bg-accent text-accent-foreground hover:bg-accent/90",
  outline:
    "border border-slate-600 bg-transparent text-white hover:border-slate-400 hover:bg-slate-800/50",
};

const classes = `${baseClasses} ${variants[variant]} ${className}`;
---

{
  href ? (
    <a href={href} class={classes} data-translate={translateKey}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes} data-translate={translateKey}>
      <slot />
    </button>
  )
}
