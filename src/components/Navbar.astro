---
import LanguageSelector from "./LanguageSelector.astro";
import NavbarMobileMenu from "./NavbarMobileMenu.astro";
import Button from "./ui/Button.astro";

const links = [
  { label: "Services", labelKey: "nav.services", href: "/#services" },
  { label: "Experience", labelKey: "nav.experience", href: "/#experience" },
  { label: "Projects", labelKey: "nav.projects", href: "/#projects" },
  { label: "Contact", labelKey: "nav.contact", href: "/#contact" },
];
---

<nav class="flex items-center justify-between gap-4 py-4">
  <a href="/" class="shrink-0">
    <span
      class="text-lg font-bold tracking-tight text-white"
      data-translate="nav.brand"
    >
      Jonathan Peraza
    </span>
  </a>

  <NavbarMobileMenu />

  <div class="hidden items-center gap-8 md:flex">
    {
      links.map((link) => (
        <a
          href={link.href}
          data-translate={link.labelKey}
          class="text-sm font-medium text-slate-400 transition-colors hover:text-white"
        >
          {link.label}
        </a>
      ))
    }
  </div>

  <div class="hidden items-center gap-3 md:flex">
    <LanguageSelector />
    <Button href="#contact" variant="primary" translateKey="nav.hireMe" class="px-5 py-2 text-xs">
      Hire Me
    </Button>
  </div>
</nav>
