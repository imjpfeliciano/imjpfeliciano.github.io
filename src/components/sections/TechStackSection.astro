---
import {
  configTranslationKeys,
  getIcon,
  pickLocalized,
  techStackItems,
  techStackMeta,
} from "../../config";
import SectionHeader from "../ui/SectionHeader.astro";
---

<section id="tech" class="mx-auto w-full max-w-6xl px-4 py-20">
  <div class="mb-12 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <SectionHeader
      labelKey="tech.label"
      titleKey="tech.title"
      label="The tools"
      title="Expertise in modern, scalable technologies."
    />
    <p class="shrink-0 text-sm text-slate-500">
      <span data-translate="tech.updatedLabel">Updated:</span>{" "}
      <span data-translate={configTranslationKeys.tech.updatedDate}>
        {pickLocalized(techStackMeta.updatedDate)}
      </span>
    </p>
  </div>

  <div class="grid grid-cols-3 gap-4 sm:grid-cols-4 md:grid-cols-6">
    {
      techStackItems.map((item) => {
        const Icon = getIcon(item.icon);
        const nameKey = configTranslationKeys.tech.name(item.id);

        return (
          <div class="flex aspect-square flex-col items-center justify-center gap-2 rounded-xl border border-slate-800 bg-surface p-4 transition-colors hover:border-slate-700">
            <Icon class="size-7 text-slate-300" stroke-width={1.5} />
            <span
              class="text-xs font-medium text-slate-400"
              data-translate={nameKey}
            >
              {pickLocalized(item.name)}
            </span>
          </div>
        );
      })
    }
  </div>
</section>
