---
import {
  configTranslationKeys,
  pickLocalized,
  pickLocalizedList,
  workHistoryItems,
} from "../../config";
import SectionHeader from "../ui/SectionHeader.astro";
---

<section id="experience" class="mx-auto w-full max-w-6xl px-4 py-20">
  <SectionHeader
    labelKey="work.label"
    titleKey="work.title"
    label="The journey"
    title="Work History"
    class="mb-12"
  />

  <div class="flex flex-col gap-10">
    {
      workHistoryItems.map((item) => {
        const roleKey = configTranslationKeys.work.role(item.id);
        const companyKey = configTranslationKeys.work.company(item.id);
        const periodKey = configTranslationKeys.work.period(item.id);
        const bullets = pickLocalizedList(item.bullets);

        return (
          <article class="border-b border-slate-800 pb-10 last:border-b-0 last:pb-0">
            <div class="mb-4 flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
              <div>
                <h3
                  class="text-xl font-semibold text-white"
                  data-translate={roleKey}
                >
                  {pickLocalized(item.role)}
                </h3>
                <p class="text-muted" data-translate={companyKey}>
                  {pickLocalized(item.company)}
                </p>
              </div>
              <p
                class="shrink-0 text-sm font-medium text-slate-400"
                data-translate={periodKey}
              >
                {pickLocalized(item.period)}
              </p>
            </div>
            <ul class="flex flex-col gap-2 pl-5">
              {bullets.map((text, index) => (
                <li
                  class="list-disc text-sm leading-relaxed text-muted marker:text-accent"
                  data-translate={configTranslationKeys.work.bullet(
                    item.id,
                    index,
                  )}
                >
                  {text}
                </li>
              ))}
            </ul>
          </article>
        );
      })
    }
  </div>
</section>
