---
import { ArrowUpRight, Mail, MapPin } from "@lucide/astro";
import Button from "../ui/Button.astro";
import Input from "../ui/Input.astro";
import Textarea from "../ui/Textarea.astro";
---

<section id="contact" class="mx-auto w-full max-w-6xl px-4 py-20">
  <div
    class="overflow-hidden rounded-2xl border border-slate-800 bg-surface md:grid md:grid-cols-2"
  >
    <div class="flex flex-col justify-center gap-6 bg-slate-950/60 p-8 md:p-12">
      <h2
        class="text-3xl font-bold text-white md:text-4xl"
        data-translate="contact.heading"
      >
        Let's build something.
      </h2>
      <p
        class="text-muted leading-relaxed"
        data-translate="contact.subtext"
      >
        Available for freelance projects and full-time opportunities. Tell me
        about your project and I'll get back to you within 24 hours.
      </p>
      <div class="flex flex-col gap-4">
        <a
          href="mailto:jperazafeliciano@gmail.com"
          class="inline-flex items-center gap-3 text-sm text-slate-300 transition-colors hover:text-white"
        >
          <Mail class="size-4 text-accent" />
          <span data-translate="contact.email">jperazafeliciano@gmail.com</span>
        </a>
        <p class="inline-flex items-center gap-3 text-sm text-slate-300">
          <MapPin class="size-4 text-accent" />
          <span data-translate="contact.location">Guadalajara, Mexico</span>
        </p>
      </div>
    </div>

    <form class="flex flex-col gap-5 p-8 md:p-12" action="#" method="post">
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        <div class="flex flex-col gap-2">
          <label for="full-name" class="text-sm font-medium text-slate-300">
            <span data-translate="contact.form.name">Full Name</span>
          </label>
          <Input id="full-name" name="name" type="text" />
        </div>
        <div class="flex flex-col gap-2">
          <label for="email" class="text-sm font-medium text-slate-300">
            <span data-translate="contact.form.email">Email Address</span>
          </label>
          <Input id="email" name="email" type="email" />
        </div>
      </div>
      <div class="flex flex-col gap-2">
        <label for="details" class="text-sm font-medium text-slate-300">
          <span data-translate="contact.form.details">Project Details</span>
        </label>
        <Textarea id="details" name="details" rows={6} />
      </div>
      <Button type="submit" variant="primary" class="w-full">
        <span data-translate="contact.form.submit">Send Message</span>
        <ArrowUpRight class="size-4" />
      </Button>
    </form>
  </div>
</section>
