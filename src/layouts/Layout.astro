---
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Jonathan Peraza's personal website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Jonathan Peraza — Full-Stack Engineer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        const savedLang = localStorage.getItem("language");
        if (savedLang) {
          document.documentElement.lang = savedLang;
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-background text-slate-100 antialiased">
    <div class="mx-auto w-full max-w-7xl">
      <header class="sticky top-0 z-50 border-b border-slate-800/80 bg-background/90 px-4 backdrop-blur-md">
        <Navbar />
      </header>
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
